<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- Increase request size limit to 100MB for large slide/image uploads -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="104857600" />
      </requestFiltering>
    </security>

    <!-- Prevent IIS from serving files itself; let Node handle everything -->
    <staticContent>
      <remove fileExtension=".wasm" />
      <mimeMap fileExtension=".wasm" mimeType="application/wasm" />
    </staticContent>

    <rewrite>
      <rules>
        <!-- WebSocket upgrade rule (must come BEFORE the HTTP catch-all) -->
        <rule name="WebSocket Proxy" stopProcessing="true">
          <match url="^ws(/.*)?$" />
          <conditions>
            <add input="{HTTP_CONNECTION}" pattern="Upgrade" />
          </conditions>
          <action type="Rewrite" url="http://localhost:3000/ws{R:1}" />
        </rule>

        <!-- Proxy all other requests to Node.js -->
        <rule name="Node.js Reverse Proxy" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{CACHE_URL}" pattern="^ws://" negate="true" />
          </conditions>
          <action type="Rewrite" url="http://localhost:3000/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <!-- Pass WebSocket upgrade headers through ARR -->
    <webSocket enabled="false" />

  </system.webServer>
</configuration>