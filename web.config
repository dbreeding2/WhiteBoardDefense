<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS web.config for WhiteBoardDefense
  ─────────────────────────────────────
  Prerequisites on the Windows 2025 server:
    1. IIS with the "Application Request Routing" (ARR) feature installed
       (via Web Platform Installer or the IIS module download page).
    2. URL Rewrite module installed.
    3. ARR proxy enabled:
         Open IIS Manager → server node → Application Request Routing Cache
         → Server Proxy Settings → Enable proxy ✓

  This config forwards all HTTP traffic (including WebSocket upgrades) to
  the Node.js process listening on port 3000.
-->
<configuration>
  <system.webServer>

    <!-- Prevent IIS from serving files itself; let Node handle everything -->
    <staticContent>
      <remove fileExtension=".wasm" />
      <mimeMap fileExtension=".wasm" mimeType="application/wasm" />
    </staticContent>

    <rewrite>
      <rules>
        <!-- WebSocket upgrade rule (must come BEFORE the HTTP catch-all) -->
        <rule name="WebSocket Proxy" stopProcessing="true">
          <match url="^ws(/.*)?$" />
          <conditions>
            <add input="{HTTP_CONNECTION}" pattern="Upgrade" />
          </conditions>
          <action type="Rewrite" url="http://localhost:3000/ws{R:1}" />
        </rule>

        <!-- Proxy all other requests to Node.js -->
        <rule name="Node.js Reverse Proxy" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{CACHE_URL}" pattern="^ws://" negate="true" />
          </conditions>
          <action type="Rewrite" url="http://localhost:3000/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <!-- Pass WebSocket upgrade headers through ARR -->
    <webSocket enabled="false" />

  </system.webServer>
</configuration>
